# 复制为 xinghui.credentials.local 并填写（此文件可提交；.local 不会进 Git）
# 填好后运行: node scripts/apply-xinghui-credentials.mjs

XINGHUI_APP_ID=
XINGHUI_API_KEY=
XINGHUI_DOMAIN=

# 若企业给完整鉴权头，填下面一行并留空 API_KEY 也可（二选一）
# XINGHUI_AUTH_HEADER=Bearer xxxxx

# 接口与默认不同时再改
# XINGHUI_API_URL=https://xingchen-api.cn-huabei-1.xf-yun.com/v2.1/tti

# 填好凭证后要真实出图：设为 1
DISABLE_MOCK=0

# 本地 CDN（可选）
CDN_BASE_URL=http://localhost:3000
