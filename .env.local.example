# ========== 真运营（见 docs/PRODUCTION-运营上线清单.md）==========

# DeepSeek 文案 AI
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_API_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 开启服务端：登录/额度/订单/生成 走 API + 数据库
SESSION_SECRET=请换成32位以上随机字符串
NEXT_PUBLIC_BACKEND_MODE=server

# 短信：dev=仅日志不发短信；aliyun=真发短信
SMS_PROVIDER=dev
# SMS_PROVIDER=aliyun
# ALIYUN_SMS_ACCESS_KEY_ID=你的AccessKeyId
# ALIYUN_SMS_ACCESS_KEY_SECRET=你的AccessKeySecret
# ALIYUN_SMS_SIGN_NAME=审核通过的签名名称
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxx（模板变量名须为 code）

# 站点正式域名（分享卡片、metadata、支付回调需一致）
NEXT_PUBLIC_APP_URL=https://www.emovalue.top

# ICP 备案号（下证后填写，全站页脚自动显示，例：粤ICP备2025xxxxxx号）
# NEXT_PUBLIC_ICP_BEIAN=粤ICP备xxxxxxxx号

# 微信业务域名校验：公众平台下载 MP_verify_XXXX.txt 放到 public/ 根目录
# 详见 docs/微信H5分享配置.md

# 支付（上线填 alipay；服务端 + 前端两个都要改）
PAY_PROVIDER=mock
# PAY_PROVIDER=alipay
# NEXT_PUBLIC_PAY_PROVIDER=alipay
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_NOTIFY_URL=https://你的域名/api/pay/notify/alipay
# ALIPAY_SANDBOX=true
# ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 定时任务（Vercel Cron 调 /api/cron/refresh-hot-topics，Header: Authorization: Bearer <CRON_SECRET>）
CRON_SECRET=请替换为随机长字符串

# 今日热点（DailyHotApi + AI 加工写入 hot_topics 表）
# DAILY_HOT_API_BASE_URL=https://api-hot.imsyy.top
# ADMIN_SECRET=单独的管理员密钥（不填则复用 CRON_SECRET）
# SITE_URL=https://你的正式域名

# 管理员手机号（逗号分隔，可访问 /admin；勿再用尾号 0000 自动提权）
ADMIN_MOBILES=

# 视频成片（上线选厂商）
VIDEO_PROVIDER=mock
# VIDEO_PROVIDER=kling
# KLING_API_KEY=
# KLING_API_BASE=
