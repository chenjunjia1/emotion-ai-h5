# 复制为 .env.local 后填写

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 后端模式：server 启用 TianAPI + 热点入库
NEXT_PUBLIC_BACKEND_MODE=server

# 会话
SESSION_SECRET=

# Pexels（今日热点封面图，仅服务端 /api/pexels/search 使用）
PEXELS_API_KEY=

# TikHub（小红书热门图文灵感，仅服务端 /api/xhs/* 使用）
TIKHUB_API_KEY=

# DeepSeek（发布包 / 热点 AI 改写）
DEEPSEEK_API_KEY=

# AI 发布包 — 高级配图（仅服务端）
# 生产推荐：Doubao-Seedream-5.0（火山方舟在线推理 ep-xxxx）
ARK_IMAGE_ENABLED=1
ARK_API_KEY=
ARK_IMAGE_ENDPOINT=
# ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_SIZE=2K
# ARK_IMAGE_SIZE_COVER=1728x2304
# ARK_IMAGE_WATERMARK=0

# 讯飞星绘 TTI（推荐）或演示模式
XINGHUI_MOCK=1
XINGHUI_APP_ID=
XINGHUI_API_KEY=
XINGHUI_API_SECRET=
# 可选：完整鉴权头（企业网关若提供 Bearer）
XINGHUI_AUTH_HEADER=
XINGHUI_API_URL=https://xingchen-api.cn-huabei-1.xf-yun.com/v2.1/tti
XINGHUI_DOMAIN=
# 本地无凭证时用演示图：XINGHUI_MOCK=1

# 图片 CDN（须为真实对象存储/CDN 域名，不要填 www.emovalue.top）
CDN_BASE_URL=
COS_UPLOAD_URL_TEMPLATE=

# 管理后台封面上传（Vercel 无本地盘时用 Supabase Storage，Dashboard 建公开桶 uploads）
SUPABASE_STORAGE_BUCKET=uploads

# 文案生成（DeepSeek）
# DEEPSEEK_API_KEY=  （见上方）

# 天聚数行 TianAPI（抖音/微博/百度/头条热榜）
TIANAPI_KEY=
TIANAPI_BASE_URL=https://apis.tianapi.com

# DailyHotApi 备用
DAILY_HOT_API_BASE_URL=

# Vercel Cron：每日 0:00 UTC = 北京时间 8:00 刷新热点
# 在 Vercel 项目 Environment 配置 CRON_SECRET，Cron 请求带 Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# 微信小程序（登录 + 订阅消息 + JSAPI 支付）
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
WECHAT_SUBSCRIBE_HOT_TOPICS_TEMPLATE_ID=
# 微信支付（小程序 PAY_PROVIDER=wechat）
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_MCH_SERIAL_NO=
WECHAT_MCH_PRIVATE_KEY=
WECHAT_PAY_NOTIFY_URL=
