.page {
  padding: 48rpx 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #fff4f7, #fff8f3);
}
.hero {
  margin-bottom: 48rpx;
}
.title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #1f2937;
}
.sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
}
.btn {
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  font-weight: 700;
}
.btn.primary {
  background: linear-gradient(90deg, #ff4f8b, #ff9a4d);
  color: #fff;
}
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 32rpx;
}
.card {
  padding: 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(255, 79, 139, 0.1);
}
.link {
  margin-top: 32rpx;
  text-align: center;
  color: #ff4f8b;
  font-size: 24rpx;
}
